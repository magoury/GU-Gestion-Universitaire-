{
  "compilerOptions": {
    // --- Config Node/Vite séparée ---
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",

    // --- Transition progressive ---
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true,

    // --- Types Node disponibles pour vite.config.ts ---
    "types": ["node"]
  },
  "include": ["vite.config.ts"]
}
